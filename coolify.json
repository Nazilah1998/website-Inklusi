{
  "$schema": "https://cdn.coollabs.io/coolify/coolify.schema.json",
  "name": "Inklusi Kemenag",
  "build": {
    "build_pack": "nixpacks",
    "install_command": "npm ci",
    "build_command": "npm run build",
    "start_command": "npm start"
  },
  "network": {
    "ports": {
      "expose": "3000"
    }
  },
  "health_check": {
    "enabled": true,
    "path": "/api/health",
    "port": "3000",
    "host": "localhost",
    "method": "GET",
    "return_code": 200,
    "scheme": "http",
    "interval": 30,
    "timeout": 10,
    "retries": 3,
    "start_period": 30
  }
}